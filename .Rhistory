library(lmerTest)
library(tidyverse)
library(here)
#### Add lexical frequency as a predictor
#### Get proficiency data for the L2 Spanish group + more for L3 group if possible
#### Expand both data sets
goodale_theme <- function() {
theme(
panel.background = element_rect(fill = "white"),
axis.text = element_text(colour = "black", family = "Times New Roman", size = 14),
axis.title = element_text(colour = "black", family = "Times New Roman", size = 14),
legend.position = "bottom",
legend.title = element_text(colour = "black", family = "Times New Roman", size = 16),
legend.text = element_text(colour = "black", family = "Times New Roman", size = 14),
plot.title = element_text(colour = "black", family = "Times New Roman", size = 14, hjust = 0.5)  # Center align the title
)
}
p_data = read.csv(here("data", "tidy", "pilot_data.csv")) %>%
filter(is_correct == 1) %>%
filter(!is.na(participant))
inc_data %>%
filter(type == "two_way_cognate" | type == "three_way_cognate")%>%
group_by(word, type) %>%
summarise(mean_rt = mean(key_resp_lextale_trial.rt)) %>%
ggplot(aes(y = word, color = type, x = mean_rt)) + geom_point()
totals = p_data %>%
group_by(type, group) %>%
summarise(total_n = n())
p_data %>%
group_by(type, group, is_correct) %>%
summarise(n = n()) %>%
left_join(totals) %>%
mutate(pct_correct = n/total_n) %>%
ggplot(aes(x = type, y = pct_correct, fill = group)) +
geom_col(position = "dodge", color = "black") + theme_minimal()
summary_data <- p_data %>%
group_by(type, group) %>%
summarize(mean_rt = mean(key_resp_lextale_trial.rt),
sd_rt = sd(key_resp_lextale_trial.rt),
n = n()) %>%
mutate(margin = qt(0.975,df=n-1)*sd_rt/sqrt(n)) %>%
mutate(upper_95_ci = mean_rt + margin,
lower_95_ci = mean_rt - margin)
summary_data_pooled <- p_data %>%
mutate(type = case_when(
type == "three_way_cognate" ~ "cognate",
type == "two_way_cognate" ~ "cognate",
type == "pseudoword" ~ "pseudoword",
type == "non_cognate" ~ "non_cognate")) %>%
group_by(type) %>%
summarize(mean_rt = mean(key_resp_lextale_trial.rt),
sd_rt = sd(key_resp_lextale_trial.rt),
n = n()) %>%
mutate(margin = qt(0.975,df=n-1)*sd_rt/sqrt(n)) %>%
mutate(upper_95_ci = mean_rt + margin,
lower_95_ci = mean_rt - margin)
summary_data_pooled %>%
ggplot(aes(y = type, x = mean_rt, color = type)) +
geom_pointrange(aes(xmin = lower_95_ci, xmax = upper_95_ci)) +
scale_color_manual(values = c("#f0ad4e", "#5cb85c", "#d9534f")) +
xlab("Word Type") +
ylab("Reaction Time (ms)") +
theme(legend.position = "none") +
ggtitle("Reaction times by word type") +
goodale_theme() + theme(legend.position="none")
summary_data %>%
ggplot(aes(y = type, x = mean_rt, color = type, shape = group)) +
geom_pointrange(aes(xmin = lower_95_ci, xmax = upper_95_ci)) +
scale_fill_manual(values = c("#f0ad4e", "#6c757d", "#5cb85c", "#d9534f")) +
xlab("Word Type") +
ylab("Reaction Time (ms)") +
theme(legend.position = "none") +
ggtitle("Reaction times of the both groups") +
goodale_theme() + theme(legend.position="none") + facet_grid(~group)
summary_data_pooled %>%
ggplot(aes(y = type, x = mean_rt, color = type)) +
geom_pointrange(aes(xmin = lower_95_ci, xmax = upper_95_ci)) +
scale_color_manual(values = c("#f0ad4e", "#5cb85c", "#d9534f")) +
xlab("Word Type") +
ylab("Reaction Time (ms)") +
theme(legend.position = "none") +
ggtitle("Reaction times by word type") +
goodale_theme() + theme(legend.position="none")
summary_data %>%
ggplot(aes(y = type, x = mean_rt, color = type, shape = group)) +
geom_pointrange(aes(xmin = lower_95_ci, xmax = upper_95_ci)) +
scale_fill_manual(values = c("#f0ad4e", "#6c757d", "#5cb85c", "#d9534f")) +
xlab("Word Type") +
ylab("Reaction Time (ms)") +
theme(legend.position = "none") +
ggtitle("Reaction times of the both groups") +
goodale_theme() + theme(legend.position="none") + facet_grid(~group)
library(tidyverse)
library(here)
library(kableExtra)
read_csv(here("docs", "manuscript", "tables", "stim_detailed.csv"),
col_types = cols(.default = "c")) %>%
mutate(type = case_when(
type == "three_way_cognate" ~ "triple cognate",
type == "two_way_cognate" ~ "double cognate",
type == "non_cognates" ~ "noncognate",
TRUE ~ type
)) %>%
rename("English" = AmE_wordform,
"German" = DE_wordform,
"Spanish" = ES_wordform,
"ONLD English-German"= NLD_orthg_AmE_DE,
"ONLD English-Spanish" = NLD_orthg_AmE_ES,
"ONLD German-Spanish" = NLD_orthg_DE_ES,
"PNLD English-German" = NLD_phonoL_AmE_DE,
"PNLD English-Spanish" = NLD_phonoL_AmE_ES,
"PNLD German-Spanish" = NLD_phonoL_DE_ES	,
"Frequency" = Subtlex_ES_log10.abs.1.,
"Word Type" = type) %>%
select(English, German, Spanish, 'Word Type') %>% # We can include the detailed table with frequency and overlap in the supplementary materials online but not in the appendix bc table is too big. We can use the same code but change the select arguments
knitr::kable(format = "pipe", booktabs = T, longtable = T,
linesep = "", escape = T, align = c("c", "c", "c", "c"),
caption = "Stimulus List ")
